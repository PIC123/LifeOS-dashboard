# Google Calendar OAuth Configuration (Recommended for personal use)
# To get these credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google Calendar API
# 4. Go to Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
# 7. Copy Client ID and Client Secret

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# After first OAuth (these get set automatically)
GOOGLE_ACCESS_TOKEN=your-access-token
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Alternative: Service Account (for server-to-server)
# GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"